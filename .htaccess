# Kapcsold be az átíró motort
RewriteEngine On

# Ha a kérés létező fájlra vagy mappára mutat, ne írd át
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Hirdetés részletek: /orszagkozepe/hirdetes/123-elado-hasznalt-mosogep
RewriteRule ^hirdetes/([0-9]+)-.*$ hirdetes_reszletek.php?id=$1 [L,QSA]

# Kategória: /orszagkozepe/kategoria/allas
RewriteRule ^kategoria/([a-zA-Z0-9_-]+)$ kategoria.php?fokategoria=$1 [L,QSA]

# Keresés
RewriteRule ^kereses$ kereses.php [L,QSA]

# Keresés AJAX
RewriteRule ^kereses_ajax\.php$ kereses_ajax.php [L,QSA]
# API végpontok
RewriteRule ^kedvencek\.php$ kedvencek.php [L,QSA]
RewriteRule ^uzenet_kuldes\.php$ uzenet_kuldes.php [L,QSA]
RewriteRule ^submit_hirdetes\.php$ submit_hirdetes.php [L,QSA]

# Auth
RewriteRule ^auth/register\.php$ auth/register.php [L,QSA]
RewriteRule ^auth/login\.php$ auth/login.php [L,QSA]
RewriteRule ^auth/logout\.php$ auth/logout.php [L,QSA]
RewriteRule ^auth/profil\.php$ auth/profil.php [L,QSA]
RewriteRule ^auth/jelszo_visszaallitas\.php$ auth/jelszo_visszaallitas.php [L,QSA]

# Admin
RewriteRule ^admin$ admin/index.php [L]
RewriteRule ^admin/$ admin/index.php [L]
RewriteRule ^admin/login$ admin/login.php [L]

# Statikus oldalak
RewriteRule ^bejelentkezes$ belepes.php [L]
RewriteRule ^belepes$ belepes.php [L]
RewriteRule ^regisztracio$ regisztracio.php [L]
RewriteRule ^fiokom$ fiokom.php [L]
RewriteRule ^hirdetes-feladas$ hirdetes_feladas.php [L]
RewriteRule ^hirdetesek$ hirdetesek.php [L]
RewriteRule ^aszf$ aszf.php [L]
RewriteRule ^adatvedelem$ adatvedelem.php [L]
RewriteRule ^gyik$ gyik.php [L]
RewriteRule ^kapcsolat$ kapcsolat.php [L]
RewriteRule ^email-megerosites$ email_megerosites.php [L]

# Alapértelmezett: index.php
RewriteRule ^$ index.php [L]
